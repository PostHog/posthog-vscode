{
    "name": "HogQL",
    "scopeName": "source.hogql",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#backtick-identifiers" },
        { "include": "#operators-word" },
        { "include": "#keywords" },
        { "include": "#functions" },
        { "include": "#operators-symbol" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-dash.hogql",
                    "match": "--.*$"
                },
                {
                    "name": "comment.line.hash.hogql",
                    "match": "#.*$"
                },
                {
                    "name": "comment.block.hogql",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.single.hogql",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        { "match": "''", "name": "constant.character.escape.hogql" },
                        { "match": "\\\\'", "name": "constant.character.escape.hogql" }
                    ]
                },
                {
                    "name": "string.quoted.double.hogql",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "match": "\"\"", "name": "constant.character.escape.hogql" }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.hogql", "match": "\\b0[xX][0-9a-fA-F]+\\b" },
                { "name": "constant.numeric.hogql", "match": "\\b(\\d+(\\.\\d*)?|\\.\\d+)([eE][+-]?\\d+)?\\b" }
            ]
        },
        "backtick-identifiers": {
            "patterns": [
                {
                    "name": "variable.other.quoted.hogql",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "operators-word": {
            "patterns": [
                {
                    "name": "keyword.operator.hogql",
                    "match": "(?i)\\b(AND|OR|NOT|IN|BETWEEN|LIKE|ILIKE|IS|NULL|UNION|INNER|JOIN|LEFT|OUTER|RIGHT|SEMI|ANTI|ANY|CROSS|FULL|ASOF)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.hogql",
                    "match": "(?i)\\b(SELECT|FROM|WHERE|GROUP|BY|ORDER|HAVING|LIMIT|OFFSET|AS|ON|CASE|WHEN|THEN|ELSE|END|DISTINCT|ALL|PREWHERE|SAMPLE|WITH|SETTINGS|FINAL|ARRAY|TOP|TOTALS|ROLLUP|CUBE|WINDOW|PARTITION|OVER|ROWS|RANGE|PRECEDING|FOLLOWING|UNBOUNDED|CURRENT|ROW|FIRST|LAST|NULLS|ASC|ASCENDING|DESC|DESCENDING|USING|COLLATE|INTERVAL|CAST|EXTRACT|SUBSTRING|TRIM|LEADING|TRAILING|BOTH|FOR|TO|DATE|DAY|HOUR|MINUTE|MONTH|QUARTER|SECOND|WEEK|YEAR|IF|INF|KEY|FN|LET|RETURN|WHILE|TRUNCATE|TIES)\\b"
                },
                {
                    "name": "constant.language.hogql",
                    "match": "(?i)\\b(TRUE|FALSE|NULL|NAN|INF)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "support.function.aggregate.hogql",
                    "match": "(?i)\\b(count|countIf|countDistinctIf|min|minIf|max|maxIf|sum|sumIf|avg|avgIf|any|anyIf|anyHeavy|anyLast|argMin|argMax|argMinIf|argMaxIf|uniq|uniqIf|uniqExact|uniqExactIf|uniqHLL12|uniqTheta|median|medianIf|medianExact|quantile|quantileIf|quantiles|stddevPop|stddevSamp|varPop|varSamp|covarPop|covarSamp|corr|groupArray|groupUniqArray|groupArrayMovingAvg|groupArrayMovingSum|groupBitAnd|groupBitOr|groupBitXor|sumWithOverflow|deltaSum|deltaSumTimestamp|sumMap|minMap|maxMap|skewSamp|skewPop|kurtSamp|kurtPop|simpleLinearRegression|windowFunnel)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.window.hogql",
                    "match": "(?i)\\b(rank|dense_rank|row_number|first_value|last_value|nth_value|lagInFrame|leadInFrame)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.datetime.hogql",
                    "match": "(?i)\\b(now|today|yesterday|toDate|toDateTime|toYear|toMonth|toDayOfMonth|toDayOfWeek|toDayOfYear|toHour|toMinute|toSecond|toQuarter|toUnixTimestamp|toStartOfYear|toStartOfMonth|toStartOfWeek|toStartOfDay|toStartOfHour|toStartOfMinute|toStartOfSecond|toStartOfQuarter|toStartOfFiveMinutes|toStartOfTenMinutes|toStartOfFifteenMinutes|toMonday|toLastDayOfMonth|toLastDayOfWeek|toYYYYMM|toYYYYMMDD|toYYYYMMDDhhmmss|dateDiff|dateAdd|dateSub|dateTrunc|dateName|monthName|age|addYears|addMonths|addWeeks|addDays|addHours|addMinutes|addSeconds|subtractYears|subtractMonths|subtractWeeks|subtractDays|subtractHours|subtractMinutes|subtractSeconds|formatDateTime|parseDateTimeBestEffort|parseDateTime|fromUnixTimestamp|toTimeZone|timeZoneOf|toTime|toISOYear|toISOWeek|timeSlot|timeSlots)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.string.hogql",
                    "match": "(?i)\\b(concat|substring|substringUTF8|upper|lower|length|lengthUTF8|trim|trimLeft|trimRight|left|right|reverse|replace|replaceAll|replaceOne|replaceRegexpAll|replaceRegexpOne|position|positionUTF8|match|extract|extractAll|like|ilike|notLike|notILike|startsWith|endsWith|base64Encode|base64Decode|repeat|format|splitByChar|splitByString|splitByRegexp|arrayStringConcat|concatWithSeparator|regexpExtract|countSubstrings|countMatches|leftPad|rightPad|ascii|encodeXMLComponent|decodeXMLComponent)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.math.hogql",
                    "match": "(?i)\\b(abs|round|floor|ceil|trunc|sqrt|cbrt|pow|power|exp|log|ln|log2|log10|sin|cos|tan|asin|acos|atan|atan2|pi|e|sign|degrees|radians|factorial|gcd|lcm|intDiv|intDivOrZero|modulo|negate|roundBankers|roundDown|roundToExp2|roundDuration|roundAge|width_bucket|hypot)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.type.hogql",
                    "match": "(?i)\\b(toInt|toFloat|toDecimal|toString|toJSONString|toUUID|toTypeName|reinterpretAsUInt8|reinterpretAsUInt16|reinterpretAsUInt32|reinterpretAsUInt64|reinterpretAsInt8|reinterpretAsInt16|reinterpretAsInt32|reinterpretAsInt64|reinterpretAsFloat32|reinterpretAsFloat64|_toInt64|_toDate)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.array.hogql",
                    "match": "(?i)\\b(array|arrayConcat|arrayElement|has|hasAll|hasAny|indexOf|arrayCount|arrayEnumerate|arrayEnumerateUniq|arrayPopBack|arrayPopFront|arrayPushBack|arrayPushFront|arrayResize|arraySlice|arraySort|arrayReverseSort|arrayUniq|arrayJoin|arrayDifference|arrayDistinct|arrayIntersect|arrayReverse|arrayFilter|arrayFlatten|arrayCompact|arrayZip|arrayMap|arrayFill|arraySplit|arrayExists|arrayAll|arrayFirst|arrayLast|arrayFirstIndex|arrayLastIndex|arrayMin|arrayMax|arraySum|arrayAvg|arrayCumSum|arrayProduct|range|empty|notEmpty)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.json.hogql",
                    "match": "(?i)\\b(isValidJSON|JSONHas|JSONLength|JSONArrayLength|JSONType|JSONExtractUInt|JSONExtractInt|JSONExtractFloat|JSONExtractBool|JSONExtractString|JSONExtractKey|JSONExtractKeys|JSONExtractRaw|JSONExtractArrayRaw|JSONExtractKeysAndValues|JSON_VALUE)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.url.hogql",
                    "match": "(?i)\\b(protocol|domain|domainWithoutWWW|topLevelDomain|port|path|pathFull|queryString|fragment|extractURLParameter|extractURLParameters|extractURLParameterNames|encodeURLComponent|decodeURLComponent|cutWWW|cutQueryString|cutFragment|cutQueryStringAndFragment|cutURLParameter|netloc)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.null.hogql",
                    "match": "(?i)\\b(isnull|isNotNull|coalesce|ifnull|nullif|assumeNotNull|toNullable|isFinite|isInfinite|isNaN|ifNotFinite|multiIf|if|transform)\\b(?=\\s*\\()"
                },
                {
                    "name": "support.function.other.hogql",
                    "match": "(?i)\\b(tuple|tupleElement|untuple|map|mapFromArrays|mapKeys|mapValues|mapContains|mapFilter|mapApply|mapUpdate|hex|unhex|bar|formatReadableSize|formatReadableQuantity|formatReadableTimeDelta|least|greatest|getSurveyResponse|languageCodeToName|plus|minus|multiply|divide|equals|notEquals|less|greater|lessOrEquals|greaterOrEquals|in|notIn|bitAnd|bitOr|bitXor|bitNot|bitShiftLeft|bitShiftRight)\\b(?=\\s*\\()"
                }
            ]
        },
        "operators-symbol": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.hogql",
                    "match": "[<>=!]+"
                },
                {
                    "name": "keyword.operator.arithmetic.hogql",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "punctuation.separator.hogql",
                    "match": "[;,.]"
                }
            ]
        }
    }
}
